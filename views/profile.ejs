<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Внешний CSS-файл страницы профиля (вместо встроенного <style>) -->
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" href="/images/favicons-39145c3850b6c70457689ce17f2f9f7c(pr-cy.ru)/favicon.ico" type="image/x-icon">
    <title>Профиль пользователя</title>
    <!-- CSRF-токен для возможного использования в AJAX -->
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
    <div class="container">
        <h1>Профиль пользователя</h1>
        <!-- Безопасный вывод данных (автоматическое экранирование HTML) -->
        <p><strong>Имя:</strong> <%= user.name %></p>
        <p><strong>Email:</strong> <%= user.email %></p>
        <a href="/main">На главную</a> | 
        <form action="/logout" method="post" style="display: inline;">
            <!-- CSRF-токен обязателен для POST-запроса выхода -->
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit">Выйти</button>
        </form>
    </div>
    <!-- Скрипт для различных улучшений (уже разрешён в CSP) -->
    <script src="/js/S-1.js"></script>
</body>
</html>
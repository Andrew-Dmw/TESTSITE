<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Внешние стили Font Awesome (если нужны иконки в будущем) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" href="/images/favicons-39145c3850b6c70457689ce17f2f9f7c(pr-cy.ru)/favicon.ico" type="image/x-icon">
    <title><%= title %></title>
    <!-- Основные стили сайта (подключаем, если нужны общие шрифты/фон) -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Стили именно для этой страницы (вынесенные из встроенного <style>) -->
    <link rel="stylesheet" href="/css/admin-incidents.css">
</head>
<body>
    <div class="container">
        <h1>Журнал инцидентов безопасности</h1>
        <div class="nav">
            <a href="/main">На главную</a>
            <a href="/ER">На юридическую модель</a>
            <a href="/admin/incidents">Обновить</a>
        </div>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Время инцидента</th>
                    <th>Время обнаружения</th>
                    <th>Описание</th>
                    <th>Статус</th>
                    <th>Уведомление отправлено</th>
                    <th>Пользователь</th>
                    <th>IP-адрес</th>
                </tr>
            </thead>
            <tbody>
                <% incidents.forEach(inc => { %>
                <tr>
                    <td><%= inc.id %></td>
                    <td><%= new Date(inc.incident_time).toLocaleString() %></td>
                    <td><%= new Date(inc.detection_time).toLocaleString() %></td>
                    <td><%= inc.description %></td>
                    <!-- Класс формируется динамически, чтобы применить цвет статуса -->
                    <td class="status-<%= inc.status %>"><%= inc.status %></td>
                    <td><%= inc.notified_at ? new Date(inc.notified_at).toLocaleString() : '—' %></td>
                    <td><%= inc.user_email || '—' %></td>
                    <td><%= inc.ip_address || '—' %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</body>
</html>